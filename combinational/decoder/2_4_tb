`timescale 1ns/1ps

module decoder2x4_tb;

reg A, B;
wire D0, D1, D2, D3;

// Instantiate the Decoder
decoder2x4 uut (
    .A(A),
    .B(B),
    .D0(D0),
    .D1(D1),
    .D2(D2),
    .D3(D3)
);

initial begin
    $display("A B | D0 D1 D2 D3");
    $monitor("%b %b | %b  %b  %b  %b", A, B, D0, D1, D2, D3);

    A = 0; B = 0; #10;
    A = 0; B = 1; #10;
    A = 1; B = 0; #10;
    A = 1; B = 1; #10;

    $finish;
end

endmodule
