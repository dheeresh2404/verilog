`timescale 1ns/1ps

module demux1x4_tb;

reg I, S0, S1;
wire Y0, Y1, Y2, Y3;

demux1x4 uut(
    .I(I),
    .S0(S0),
    .S1(S1),
    .Y0(Y0),
    .Y1(Y1),
    .Y2(Y2),
    .Y3(Y3)
);

initial begin
    I=1;

    $display("S1 S0 | Y0 Y1 Y2 Y3");

    S1=0; S0=0; #10;
    S1=0; S0=1; #10;
    S1=1; S0=0; #10;
    S1=1; S0=1; #10;

    $finish;
end

initial
$monitor("%b  %b | %b %b %b %b",S1,S0,Y0,Y1,Y2,Y3);

endmodule
