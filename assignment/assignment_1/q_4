module mux2x1(
    input A,
    input B,
    input S,
    output Y
);

assign Y = S ? B : A;

endmodule


module mux4x1(
    input I0,
    input I1,
    input I2,
    input I3,
    input S0,
    input S1,
    output Y
);

wire w1, w2;

mux2x1 M1(I0, I1, S0, w1);
mux2x1 M2(I2, I3, S0, w2);
mux2x1 M3(w1, w2, S1, Y);

endmodule
